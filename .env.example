# =============================================================================
# Environment variables for the Enterprise Air-Gapped LLM Stack.
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# =============================================================================

# --- PostgreSQL (conversation history, user accounts) ---
# Generate with:  openssl rand -base64 24 | tr -d '=+/' | cut -c1-32
PG_PASSWORD=replace_with_random_32_char_password

# --- Redis (session cache) ---
# Generate with:  openssl rand -base64 24 | tr -d '=+/' | cut -c1-32
REDIS_PASSWORD=replace_with_random_32_char_password

# --- Open WebUI session secret ---
# Generate with:  openssl rand -hex 32
WEBUI_SECRET=replace_with_64_hex_chars

# --- Display name shown on the login page and browser tab ---
WEBUI_NAME=Enterprise AI Assistant
